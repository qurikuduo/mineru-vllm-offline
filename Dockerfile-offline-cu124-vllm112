# Install libgl for opencv support & Noto fonts for Chinese characters
RUN echo "nameserver 223.5.5.5" > /etc/resolv.conf && \
    echo "nameserver 114.114.114.114" >> /etc/resolv.conf && \
    find /etc/apt -name "sources.list*" -type f -exec sed -i 's|http[s]*://[^/ ]*archive.ubuntu.com|http://mirror.nju.edu.cn/ubuntu|g' {} + && \
    find /etc/apt -name "sources.list*" -type f -exec sed -i 's|http[s]*://[^/ ]*security.ubuntu.com|http://mirror.nju.edu.cn/ubuntu|g' {} + && \
    apt-get update && \
    apt-get install -y \
      fonts-noto-core \
      fonts-noto-cjk \
      fontconfig \
      libgl1 && \
    fc-cache -fv && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install mineru latest
RUN python3 -m pip install -U 'mineru[core]>=3.0.0' -i https://mirror.nju.edu.cn/pypi/web/simple --break-system-packages && \
    python3 -m pip cache purge

# Download models and update the configuration file
RUN /bin/bash -c "mineru-models-download -s modelscope -m all"

# ====== 新增：修复 VLM 模型的 HuggingFace 缓存结构 ======
RUN mkdir -p /root/.cache/huggingface/hub/models--opendatalab--MinerU2.5-Pro-2604-1.2B/snapshots/0000000000000000 && \
    mkdir -p /root/.cache/huggingface/hub/models--opendatalab--MinerU2.5-Pro-2604-1.2B/refs && \
    echo "0000000000000000" > /root/.cache/huggingface/hub/models--opendatalab--MinerU2.5-Pro-2604-1.2B/refs/main && \
    ln -sf /root/.cache/modelscope/hub/models/OpenDataLab/MinerU2.5-Pro-2604-1.2B/* /root/.cache/huggingface/hub/models--opendatalab--MinerU2.5-Pro-2604-1.2B/snapshots/0000000000000000/
# =======================================================

# ====== 新增：将离线和屏蔽代理固化到镜像环境变量中 ======
ENV MINERU_MODEL_SOURCE=local \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    HTTP_PROXY="" \
    HTTPS_PROXY="" \
    http_proxy="" \
    https_proxy=""
# =======================================================

# Set the entry point (因为环境变量已经通过 ENV 设置，这里可以简化)
ENTRYPOINT ["/bin/bash", "-c", "exec \"$@\"", "--"]

